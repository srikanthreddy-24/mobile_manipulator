<?xml version="1.0"?>
<robot name="mobile_manipulator">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.15"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <link name="wheel_left"><visual><geometry><cylinder radius="0.1" length="0.05"/></geometry><material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material></visual></link>
  <link name="wheel_right"><visual><geometry><cylinder radius="0.1" length="0.05"/></geometry><material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material></visual></link>
  
  <joint name="base_to_left_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.22 -0.05" rpy="1.5708 0 0"/>
  </joint>
  <joint name="base_to_right_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.22 -0.05" rpy="1.5708 0 0"/>
  </joint>

  <link name="arm_base">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
  </link>
  <joint name="chassis_to_arm_base" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0.15 0 0.1" rpy="0 0 0"/> </joint>

  <link name="link_1_waist">
    <visual><geometry><cylinder radius="0.06" length="0.15"/></geometry><material name="white"><color rgba="1 1 1 1"/></material></visual>
  </link>
  <joint name="joint_1_waist" type="revolute">
    <parent link="arm_base"/>
    <child link="link_1_waist"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_2_shoulder">
    <visual><geometry><cylinder radius="0.04" length="0.3"/></geometry><origin xyz="0 0 0.15" rpy="0 0 0"/><material name="grey"/></visual>
  </link>
  <joint name="joint_2_shoulder" type="revolute">
    <parent link="link_1_waist"/>
    <child link="link_2_shoulder"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_3_elbow">
    <visual><geometry><cylinder radius="0.035" length="0.25"/></geometry><origin xyz="0 0 0.125" rpy="0 0 0"/><material name="white"/></visual>
  </link>
  <joint name="joint_3_elbow" type="revolute">
    <parent link="link_2_shoulder"/>
    <child link="link_3_elbow"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_4_wrist">
    <visual><geometry><cylinder radius="0.03" length="0.1"/></geometry><origin xyz="0 0 0.05" rpy="0 0 0"/><material name="grey"/></visual>
  </link>
  <joint name="joint_4_wrist" type="revolute">
    <parent link="link_3_elbow"/>
    <child link="link_4_wrist"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_5_wrist_roll">
    <visual><geometry><cylinder radius="0.025" length="0.08"/></geometry><origin xyz="0 0 0.04" rpy="0 0 0"/><material name="white"/></visual>
  </link>
  <joint name="joint_5_roll" type="revolute">
    <parent link="link_4_wrist"/>
    <child link="link_5_wrist_roll"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_6_tool">
    <visual><geometry><box size="0.02 0.08 0.02"/></geometry><origin xyz="0 0 0.01" rpy="0 0 0"/><material name="blue"/></visual>
  </link>
  <joint name="joint_6_tool" type="revolute">
    <parent link="link_5_wrist_roll"/>
    <child link="link_6_tool"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

</robot>